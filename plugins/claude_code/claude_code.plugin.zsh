# Claude Code aliases
alias ccr='claude --resume'                              # resume a conversation
alias ccc='claude --continue'                            # continue last conversation
alias ccp='claude --print'                               # non-interactive/pipe mode
alias cccommit='claude /commit'                          # run commit skill
alias ccpr='claude /create-pr'                           # run custom pull request skill
alias ccct='claude /create-ticket'                       # run custom create ticket skill
alias ccw="claude --worktree"                            # run with worktree context
